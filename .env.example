# Solana RPC endpoint (required)
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Wallet secret key: base58 or JSON byte array from solana-keygen (required)
PRIVATE_KEY=

# 3 Kamino Earn (K-Vault) addresses sharing the same underlying mint (required)
# Examples (USDC vaults — verify before mainnet use):
# Steakhouse USDC (conservative): HDsayqAsDWy3QvANGqh2yNraqcD8Fnjgh73Mhb3WRS5E
# Allez USDC (balanced): A1USdzqDHmw5oz97AkqAGLxEQZfFjASZFuy4T6Qdvnpo
# RockawayX RWA USDC (balanced): DWSXb18xZApz29vnQpgR2m6MynCT7PznaXt7Ut7M7KaP
VAULT_ADDRESSES=HDsayqAsDWy3QvANGqh2yNraqcD8Fnjgh73Mhb3WRS5E,A1USdzqDHmw5oz97AkqAGLxEQZfFjASZFuy4T6Qdvnpo,DWSXb18xZApz29vnQpgR2m6MynCT7PznaXt7Ut7M7KaP

# Max underlying token units to move per rebalance cycle, decimal string (required)
MAX_ALLOCATION=4

# Skip moves below this token amount (optional)
MIN_MOVE_AMOUNT=0.1

# Total runtime in seconds; omit to run indefinitely
RUN_SECONDS=

# Rebalance interval in seconds (default: 900 = 15 minutes)
REBALANCE_INTERVAL_SECONDS=30

# When true, plan and log only — no transactions (default: true)
DRY_RUN=true
