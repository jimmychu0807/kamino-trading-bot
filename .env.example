# Solana RPC endpoint (required)
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Wallet secret key: base58 or JSON byte array from solana-keygen (required)
PRIVATE_KEY=

# Exactly 3 Kamino Earn (K-Vault) addresses sharing the same underlying mint (required)
# Examples (USDC vaults — verify before mainnet use):
VAULT_ADDRESSES=HDsayqAsDWy3QvANGqh2yNraqcD8Fnjgh73Mhb3WRS5E,A1USdzqDHmw5oz97AkqAGLxEQZfFjASZFuy4T6Qdvnpo

# Max reserve principal deployable into vaults (yield growth does not count), decimal string (required)
MAX_ALLOCATION=100

# Total runtime in seconds; omit to run indefinitely
# RUN_SECONDS=3600

# Rebalance interval in seconds (default: 900 = 15 minutes)
# REBALANCE_INTERVAL_SECONDS=900

# When true, plan and log only — no transactions (default: true)
DRY_RUN=true

# Skip moves below this token amount (optional)
# MIN_MOVE_AMOUNT=1

# Integration tests: optional wallet with vault positions
# TEST_WALLET=

# Optional live e2e with real transactions (not for CI)
# E2E_LIVE=false
