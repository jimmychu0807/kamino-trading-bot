SOLANA_RPC=https://api.mainnet-beta.solana.com
PRIVATE_KEY=<YOUR_BASE58_PRIVATE_KEY>

# Three Kamino Earn vault addresses (comma-separated)
# Steakhouse USDC (conservative): HDsayqAsDWy3QvANGqh2yNraqcD8Fnjgh73Mhb3WRS5E
# Allez USDC (balanced): A1USdzqDHmw5oz97AkqAGLxEQZfFjASZFuy4T6Qdvnpo
# Elemental USDG Optimizer (aggresive): DJbRxuBckoJpFVUNtWx94NghcthfGaRV5NRmEazUaddE
VAULTS=HDsayqAsDWy3QvANGqh2yNraqcD8Fnjgh73Mhb3WRS5E,A1USdzqDHmw5oz97AkqAGLxEQZfFjASZFuy4T6Qdvnpo,DJbRxuBckoJpFVUNtWx94NghcthfGaRV5NRmEazUaddE

# Safety: default preview (no on-chain txs). Loader defaults to true when unset.
PREVIEW_MODE=true

# Scheduling (every 15 mins)
CRON_EXPRESSION=*/15 * * * *

# FR-013 optional drift-triggered cycles (off by default)
DRIFT_TRIGGER_ENABLED=false
DRIFT_POLL_INTERVAL_MS=300000

# Policy & cycle limits (see contracts/config.schema.json; full Zod loader in Phase 2)
RISK_PROFILE=balanced
METRICS_MAX_AGE_MS=900000
RPC_TIMEOUT_MS=15000
CYCLE_TIMEOUT_MS=180000
LEG_MAX_ATTEMPTS=3
CONSECUTIVE_FAILURE_THRESHOLD=3

# SQLite (gitignored path)
DATABASE_URL=./data/bot.sqlite

# Optional alerts
# ALERT_WEBHOOK_URL=
