{
	"name": "test01-kamino",
	"module": "index.ts",
	"type": "module",
	"scripts": {
		"start": "bun run src/index.ts",
		"cli": "bun run src/cli.ts",
		"test": "bun test tests/unit",
		"test:e2e": "RUN_E2E_TESTS=true bun test tests/e2e",
		"test:e2e:slow": "RUN_E2E_TESTS=true E2E_SLOW=true bun test tests/e2e",
		"test:integration": "RUN_INTEGRATION_TESTS=true bun test tests/integration --timeout 10000",
		"compile": "bunx --bun tsc --noEmit",
		"check": "bunx biome check",
		"format": "bunx biome check --write",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run src/db/migrate.ts"
	},
	"dependencies": {
		"@kamino-finance/klend-sdk": "^7.3.22",
		"@solana/kit": "^2.3.0",
		"drizzle-orm": "^0.39.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bun": "latest",
		"drizzle-kit": "^0.30.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"overrides": {
		"@kamino-finance/farms-sdk": "3.2.24",
		"@solana/kit": "2.3.0"
	}
}
