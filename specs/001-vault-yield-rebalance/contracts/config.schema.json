{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "kamino-rebalancer/config",
	"title": "OperatorConfig",
	"description": "Validated operator configuration (mirrors Zod schema in src/config/schema.ts)",
	"type": "object",
	"required": [
		"solanaRpc",
		"vaults",
		"policy",
		"previewMode",
		"metricsMaxAgeMs",
		"rpcTimeoutMs",
		"cycleTimeoutMs",
		"cronExpression"
	],
	"properties": {
		"solanaRpc": { "type": "string", "format": "uri" },
		"previewMode": {
			"type": "boolean",
			"default": true,
			"description": "When true, log decisions only; no on-chain txs. Env PREVIEW_MODE overrides; loader MUST default to true if unset (safety)."
		},
		"driftTriggerEnabled": {
			"type": "boolean",
			"default": false,
			"description": "FR-013: optional extra runCycle when allocation drift exceeds policy.driftBandPct"
		},
		"driftPollIntervalMs": {
			"type": "integer",
			"minimum": 60000,
			"default": 300000,
			"description": "Poll interval for drift trigger when enabled (default 5 min)"
		},
		"metricsMaxAgeMs": {
			"type": "integer",
			"minimum": 60000,
			"default": 900000
		},
		"rpcTimeoutMs": { "type": "integer", "minimum": 1000, "default": 15000 },
		"cycleTimeoutMs": {
			"type": "integer",
			"minimum": 30000,
			"default": 180000
		},
		"legMaxAttempts": {
			"type": "integer",
			"minimum": 1,
			"maximum": 10,
			"default": 3
		},
		"consecutiveFailureThreshold": {
			"type": "integer",
			"minimum": 1,
			"default": 3
		},
		"apySpikeGuardMultiple": {
			"type": "number",
			"minimum": 1,
			"default": 3,
			"description": "Skip trading when vault APY exceeds this multiple of trailing average"
		},
		"cronExpression": { "type": "string", "default": "0 * * * *" },
		"vaults": {
			"type": "array",
			"minItems": 3,
			"maxItems": 3,
			"items": {
				"type": "object",
				"required": ["address"],
				"properties": {
					"address": {
						"type": "string",
						"pattern": "^[1-9A-HJ-NP-Za-km-z]{32,44}$"
					},
					"label": { "type": "string" },
					"minAllocationPct": {
						"type": "number",
						"minimum": 0,
						"maximum": 100
					},
					"maxAllocationPct": {
						"type": "number",
						"minimum": 0,
						"maximum": 100
					},
					"enabled": { "type": "boolean", "default": true }
				}
			}
		},
		"policy": {
			"type": "object",
			"required": ["profile"],
			"properties": {
				"profile": {
					"type": "string",
					"enum": ["conservative", "balanced", "aggressive"]
				},
				"minImprovementBps": { "type": "integer", "minimum": 0 },
				"maxSingleVaultPct": { "type": "number", "minimum": 1, "maximum": 100 },
				"minTradeSizeBase": { "type": "string", "pattern": "^[0-9]+$" },
				"cooldownMs": { "type": "integer", "minimum": 0 },
				"driftBandPct": { "type": "number", "minimum": 0, "maximum": 50 },
				"cashBufferPct": { "type": "number", "minimum": 0, "maximum": 10 },
				"criticalRiskFloor": { "type": "number", "minimum": 0, "maximum": 1 },
				"riskWeights": {
					"type": "object",
					"properties": {
						"liquidity": { "type": "number" },
						"utilization": { "type": "number" },
						"concentration": { "type": "number" },
						"volatility": { "type": "number" }
					}
				}
			}
		}
	}
}
